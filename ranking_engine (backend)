"""
ranking_engine.py – Semantic similarity ranking using sentence-transformers.

Model: all-MiniLM-L6-v2 (fast, good quality, ~80 MB)
"""

from __future__ import annotations
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity
from sentence_transformers import SentenceTransformer
from resume_parser import extract_skills

# Load once at module import time (cached after first load)
_MODEL_NAME = "all-MiniLM-L6-v2"
print(f"[ranking_engine] Loading model '{_MODEL_NAME}' …")
_model = SentenceTransformer(_MODEL_NAME)
print("[ranking_engine] Model ready.")


def get_embedding(text: str) -> np.ndarray:
    """Return the sentence embedding for a piece of text."""
    # Truncate to avoid token limits (model handles internally, but be explicit)
    embedding = _model.encode(text, show_progress_bar=False, convert_to_numpy=True)
    return embedding.reshape(1, -1)  # shape (1, D)


def rank_resumes(
    jd_text: str,
    resumes: list[dict],
) -> list[dict]:
    """
    Rank resumes by semantic similarity to the job description.

    Parameters
    ----------
    jd_text : str
        The job description text.
    resumes : list[dict]
        Each dict must have at least:
            - "name"     (str) candidate name
            - "text"     (str) extracted resume text
            - "skills"   (list[str]) detected skills
            - "filename" (str) original uploaded filename

    Returns
    -------
    list[dict] – ranked from highest to lowest score, each entry:
        {
            "rank": int,
            "name": str,
            "score": float,          # 0–100 percentage
            "skills": list[str],
            "filename": str,
        }
    """
    if not resumes:
        return []

    jd_embedding = get_embedding(jd_text)
    jd_skills_list = extract_skills(jd_text, auto_keywords=True)
    jd_skills = set(jd_skills_list)

    scored: list[dict] = []
    for resume in resumes:
        resume_text = resume.get("text", "")
        if not resume_text.strip():
            score = 0.0
            matched_skills = []
            missing_skills = []
            skill_coverage = 0.0
            exp_level = "Entry Level"
            resume_strength = 0
            match_explanation = ["❌ Empty or unreadable resume."]
        else:
            resume_embedding = get_embedding(resume_text)
            sim = cosine_similarity(jd_embedding, resume_embedding)[0][0]
            
            # 1. Normalize semantic score (cosine similarity usually falls between 0.15 and 0.65 for real docs)
            semantic_score = (sim - 0.15) / 0.50
            semantic_score = float(np.clip(semantic_score, 0.0, 1.0)) * 100
            
            # 2. Skill match bonus
            matched_skills = []
            missing_skills = []
            extra_skills = []
            skill_coverage = 0.0
            
            resume_skills = set(resume.get("skills", []))
            
            if jd_skills:
                matched = jd_skills.intersection(resume_skills)
                matched_skills = sorted(list(matched))
                missing_skills = sorted(list(jd_skills - matched))
                extra_skills = sorted(list(resume_skills - jd_skills))
                
                skill_coverage = (len(matched) / len(jd_skills)) * 100
                # Weighted average: 60% semantic, 40% exact skill match
                score = (semantic_score * 0.6) + (skill_coverage * 0.4)
            else:
                score = semantic_score
                extra_skills = sorted(list(resume_skills))

            # 3. Experience level extraction
            import re
            text_lower = resume_text.lower()
            exp_level = "Entry Level"
            years_match = re.findall(r'(\d+)\+?\s*(?:-?\s*\d+)?\s*years?(?:\s+of)?\s+experience', text_lower)
            if years_match:
                try:
                    max_years = max(int(y) for y in years_match)
                    if max_years >= 7:
                        exp_level = "Senior"
                    elif max_years >= 3:
                        exp_level = "Mid-level"
                    elif max_years > 0:
                        exp_level = "Junior"
                except Exception:
                    pass
            elif "senior" in text_lower or "lead" in text_lower or "principal" in text_lower:
                exp_level = "Senior"
            elif "intern" in text_lower or "fresher" in text_lower:
                exp_level = "Entry Level"
                
            # 4. Resume Strength (quality score 0-100)
            len_score = min(50, (len(resume_text) / 4000) * 50)
            skills_score = min(50, (len(resume.get("skills", [])) / 25) * 50)
            resume_strength = int(round(len_score + skills_score))
            
            # 5. Match Explanation
            match_explanation = []
            if score >= 85:
                match_explanation.append("✔ Highly relevant semantic match with job description.")
            elif score >= 60:
                match_explanation.append("✔ Good semantic match, covers key requirements.")
            else:
                match_explanation.append("⚠ Weak semantic match. Content differs from JD.")
                
            if jd_skills:
                if skill_coverage >= 80:
                    match_explanation.append(f"✔ Exceptional skill coverage ({len(matched_skills)}/{len(jd_skills)} required skills).")
                elif skill_coverage >= 40:
                    match_explanation.append(f"✔ Moderate skill coverage ({len(matched_skills)}/{len(jd_skills)} required skills).")
                else:
                    miss_str = ", ".join(missing_skills[:3])
                    if len(missing_skills) > 3: miss_str += "..."
                    match_explanation.append(f"❌ Poor skill coverage. Missing critical skills like {miss_str}.")
                    
            if exp_level == "Senior":
                match_explanation.append("✔ Detected extensive professional experience.")

        scored.append({
            "name": resume.get("name", "Unknown"),
            "score": round(score, 2),
            "skills": resume.get("skills", []),
            "matched_skills": matched_skills,
            "missing_skills": missing_skills,
            "extra_skills": extra_skills,
            "skill_coverage": round(skill_coverage, 1),
            "experience_level": exp_level,
            "resume_strength": resume_strength,
            "match_explanation": match_explanation,
            "text": resume_text,
            "filename": resume.get("filename", ""),
        })

    # Sort descending by score
    scored.sort(key=lambda x: x["score"], reverse=True)

    # Assign ranks
    for i, item in enumerate(scored):
        item["rank"] = i + 1

    return scored
