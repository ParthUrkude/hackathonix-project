# Build a lower-cased lookup for fast matching
_SKILLS_LOWER = {s.lower(): s for s in SKILLS_VOCABULARY}


def extract_skills(text: str, auto_keywords: bool = False) -> list[str]:
    """Return a de-duplicated list of detected skills. If auto_keywords is True and no skills found, try to extract nouns."""
    if not text:
        return []

    text_lower = text.lower()
    found = set()

    for skill_lower, skill_display in _SKILLS_LOWER.items():
        # Use word-boundary-aware search for short skills (<= 3 chars avoid false positives)
        if len(skill_lower) <= 2:
            pattern = r'\b' + re.escape(skill_lower) + r'\b'
        else:
            pattern = re.escape(skill_lower)
        if re.search(pattern, text_lower):
            found.add(skill_display)

    if not found and auto_keywords:
        # Fallback: Extract words that look like keywords
        # 1. Any word 3+ chars long that starts with an Uppercase letter (Proper Nouns/Skills)
        # 2. Any word 4+ chars long that isn't a common stop word
        STOP_WORDS = {
            "looking", "required", "experience", "candidate", "position", "company", "skills", 
            "ability", "working", "knowledge", "years", "description", "requirements",
            "highly", "strong", "excellent", "provide", "within", "across", "support",
            "please", "wanted", "needed", "about", "would", "could", "should", "there"
        }
        # Title case words (3+) or any words (4+)
        candidates = re.findall(r'\b[A-Z][a-z]{2,}\b|\b[A-Za-z]{4,}\b', text)
        for w in candidates:
            if w.lower() not in STOP_WORDS:
                found.add(w.strip('.,()'))
        
        # Sort by length (desc) then alpha to get "better" keywords first, then take top 15
        sorted_found = sorted(list(found), key=lambda x: (-len(x), x))
        return sorted_found[:15]

    return sorted(found)
