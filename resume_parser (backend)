"""
resume_parser.py – Extract text and skills from PDF/DOCX resumes.
"""

import os
import re
from pathlib import Path

# ---------------------------------------------------------------------------
# PDF parsing (pdfplumber preferred, PyPDF2 as fallback)
# ---------------------------------------------------------------------------

def parse_pdf(file_path: str) -> str:
    """Extract text from a PDF file."""
    text = ""
    # Try pdfplumber first (handles complex layouts better)
    try:
        import pdfplumber
        with pdfplumber.open(file_path) as pdf:
            for page in pdf.pages:
                page_text = page.extract_text()
                if page_text:
                    text += page_text + "\n"
        if text.strip():
            return text
    except Exception:
        pass

    # Fallback: PyPDF2
    try:
        import PyPDF2
        with open(file_path, "rb") as f:
            reader = PyPDF2.PdfReader(f)
            for page in reader.pages:
                page_text = page.extract_text()
                if page_text:
                    text += page_text + "\n"
    except Exception as e:
        print(f"[resume_parser] PDF parse error for {file_path}: {e}")

    return text


# ---------------------------------------------------------------------------
# DOCX parsing
# ---------------------------------------------------------------------------

def parse_docx(file_path: str) -> str:
    """Extract text from a DOCX file."""
    try:
        from docx import Document
        doc = Document(file_path)
        paragraphs = [para.text for para in doc.paragraphs if para.text.strip()]
        return "\n".join(paragraphs)
    except Exception as e:
        print(f"[resume_parser] DOCX parse error for {file_path}: {e}")
        return ""


# ---------------------------------------------------------------------------
# Dispatcher
# ---------------------------------------------------------------------------

def extract_text(file_path: str) -> str:
    """Auto-detect file type and extract text."""
    ext = Path(file_path).suffix.lower()
    if ext == ".pdf":
        return parse_pdf(file_path)
    elif ext in (".docx", ".doc"):
        return parse_docx(file_path)
    else:
        # Try reading as plain text
        try:
            with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                return f.read()
        except Exception:
            return ""


# ---------------------------------------------------------------------------
# Candidate name derivation
# ---------------------------------------------------------------------------

def extract_name(filename: str) -> str:
    """
    Derive a human-readable candidate name from the filename.
    E.g. 'john_doe_resume.pdf' → 'John Doe'
    """
    stem = Path(filename).stem  # strip extension
    # Remove common suffixes
    stem = re.sub(r'(?i)[_\-\s]*(resume|cv|application|final|updated|new)', '', stem)
    # Replace separators with spaces
    stem = re.sub(r'[_\-\.]+', ' ', stem)
    stem = stem.strip()
    # Title-case each word
    return stem.title() if stem else filename


